# Supabase Configuration
# Reemplaza con tus credenciales de Supabase

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Service Role Key (para operaciones administrativas/cron jobs)
# Obtener en: Supabase Dashboard > Settings > API > Service Role Key
# ⚠️ IMPORTANTE: Esta variable NO debe exponerse en el frontend
# Solo usar en Netlify Functions o backend
VITE_SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
